# Axios baseURL (see src/api.ts). Must end with /api — FastAPI mounts REST under /api.
#
# Local dev: leave unset to use Vite’s proxy (/api → http://127.0.0.1:8000), or set:
#   VITE_API_BASE_URL=http://127.0.0.1:8000/api
#
# Vercel (Production + Preview): set in Project → Settings → Environment Variables:
#   VITE_API_BASE_URL=https://ski-ai-api-production.up.railway.app/api
# Rebuild after changing; value is baked in at build time.
